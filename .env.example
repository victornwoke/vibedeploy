# VibeDeploy MVP environment variables

# No required runtime secrets for the static MVP.
# This repository is designed to run without backend API keys for core functionality.

# Optional server port for the Express static server in production.
# PORT=3000

# Do not place private API keys or production credentials in VITE_* variables because frontend variables are public.

## Optional frontend integrations
# Formspree contact form (public form ID). Replace with your Formspree form ID.
# VITE_* variables are public in Vite. The Formspree form ID is acceptable to
# expose, but do not place private API keys in frontend environment variables.
VITE_FORMSPREE_CONTACT_FORM_ID=your_formspree_form_id_here
